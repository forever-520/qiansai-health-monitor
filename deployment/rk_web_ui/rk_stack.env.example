WEB_USER=admin
WEB_PASS=change-this-password
HOST=0.0.0.0
PORT=8081

DATA_MODE=gateway
DATA_HTTP_URL=http://127.0.0.1:8000
DATA_WS_URL=ws://127.0.0.1:8001/ws

# Use auto to scan the current WiFi/LAN for a LubanCat serving /radar/raw.
LUBANCAT_HOST=auto
LUBANCAT_PREFERRED_HOSTS=
LUBANCAT_PORT=9001
REMOTE_RADAR_URL=auto
REMOTE_CAMERA_CAPTURE_URL=auto
GATEWAY_HTTP_PORT=8000
GATEWAY_WS_PORT=8001
GATEWAY_RATE=20.0
CAMERA_PROXY_TIMEOUT=40.0
CAMERA_JPEG_MAX_SIDE=960
CAMERA_JPEG_QUALITY=75
